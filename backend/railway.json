{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run prisma:generate && npm run build && npx prisma db push",
    "startCommand": "node dist/main"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "NEVER",
    "restartPolicyMaxRetries": 0
  }
}